# MiMo V2.5 API Configuration
MIMO_API_KEY=your-mimo-api-key-here
MIMO_API_BASE_URL=https://api.mimo.xiaomi.com/v2.5
MIMO_MODEL=mimo-v2.5
MIMO_MAX_TOKENS=32768
MIMO_TEMPERATURE=0.3

# Redis Configuration (for MessageBus)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Coordinator Settings
SWARM_MAX_AGENTS=5
SWARM_MAX_CONCURRENT_TASKS=10
SWARM_CONFLICT_RESOLUTION=true
SWARM_DEFAULT_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Web3 / Crypto
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
ETH_CHAIN_ID=1
